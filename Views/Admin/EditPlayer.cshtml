@{
    ViewData["Title"] = "Spieler bearbeiten";

    var user = ViewBag.User as SEW04_Projekt_Bsteh.Models.ApplicationUser;
    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userBuildings = ViewBag.UserBuildings as List<SEW04_Projekt_Bsteh.Models.UserBuilding>;
    var userResources = ViewBag.UserResources as List<SEW04_Projekt_Bsteh.Models.UserResource>;
    var userAchievements = ViewBag.UserAchievements as List<SEW04_Projekt_Bsteh.Models.UserAchievement>;
}

<div class="container mt-4">
    <h1>Spieler bearbeiten: @(user?.DisplayName)</h1>
    <p>E-Mail: <strong>@(user?.Email)</strong></p>

    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    @if (farm != null)
    {
        <!-- Reset Button -->
        <button class="btn btn-danger mb-4" onclick="resetPlayer('@(user?.Id)')">
            Komplett zuruecksetzen (Totalreset)
        </button>

        <!-- Farm-Daten -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Farm-Daten / Cheats</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Geld</label>
                        <input type="number" id="farm-money" class="form-control" step="0.01" value="@(farm.Money.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Rebirth-Multiplikator</label>
                        <input type="number" id="farm-multiplier" class="form-control" step="0.1" value="@(farm.RebirthMultiplier.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Rebirth-Anzahl</label>
                        <input type="number" id="farm-rebirths" class="form-control" value="@(farm.RebirthCount)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Verteilung freigeschaltet</label>
                        <select id="farm-allocation" class="form-select">
                            @if (farm.AllocationUnlocked)
                            {
                                <option value="true" selected>Ja</option>
                                <option value="false">Nein</option>
                            }
                            else
                            {
                                <option value="true">Ja</option>
                                <option value="false" selected>Nein</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Produktionsbonus</label>
                        <input type="number" id="farm-prodbonus" class="form-control" step="0.01" value="@(farm.AchievementProductionBonus.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Verkaufsbonus</label>
                        <input type="number" id="farm-sellbonus" class="form-control" step="0.01" value="@(farm.AchievementSellBonus.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Upgrade-Rabatt</label>
                        <input type="number" id="farm-discount" class="form-control" step="0.01" value="@(farm.AchievementUpgradeDiscount.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Lagerbonus</label>
                        <input type="number" id="farm-storagebonus" class="form-control" step="0.01" value="@(farm.AchievementStorageBonus.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                </div>
                <button class="btn btn-primary" onclick="saveFarm('@(user?.Id)')">Farm speichern</button>
            </div>
        </div>

        <!-- Gebaeude -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Gebaeude</h5>
            </div>
            <div class="card-body">
                @if (userBuildings != null)
                {
                    @foreach (var ub in userBuildings)
                    {
                        <div class="mb-3 p-3" style="background: rgba(0,0,0,0.03); border-radius: 8px;">
                            <h6>@(ub.Building.Name)</h6>
                            <div class="row">
                                <div class="col-md-2">
                                    <label class="form-label">Freigeschaltet</label>
                                    <select id="bld-unlocked-@(ub.BuildingId)" class="form-select">
                                        @if (ub.IsUnlocked)
                                        {
                                            <option value="true" selected>Ja</option>
                                            <option value="false">Nein</option>
                                        }
                                        else
                                        {
                                            <option value="true">Ja</option>
                                            <option value="false" selected>Nein</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Produktion Lv.</label>
                                    <input type="number" id="bld-prod-@(ub.BuildingId)" class="form-control" value="@(ub.ProductionLevel)" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Effizienz Lv.</label>
                                    <input type="number" id="bld-eff-@(ub.BuildingId)" class="form-control" value="@(ub.EfficiencyLevel)" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Kapazitaet Lv.</label>
                                    <input type="number" id="bld-cap-@(ub.BuildingId)" class="form-control" value="@(ub.CapacityLevel)" />
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button class="btn btn-warning btn-sm w-100"
                                            onclick="saveBuilding('@(user?.Id)', @(ub.BuildingId))">
                                        Speichern
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Ressourcen -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Ressourcen</h5>
            </div>
            <div class="card-body">
                @if (userResources != null)
                {
                    @foreach (var ur in userResources)
                    {
                        <div class="mb-3 p-3" style="background: rgba(0,0,0,0.03); border-radius: 8px;">
                            <h6>@(ur.Resource.Name)</h6>
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label">Menge</label>
                                    <input type="number" id="res-amount-@(ur.ResourceId)" class="form-control" step="0.1" value="@(ur.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Max Lager</label>
                                    <input type="number" id="res-max-@(ur.ResourceId)" class="form-control" step="1" value="@(ur.MaxStorage.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <button class="btn btn-warning btn-sm w-100"
                                            onclick="saveResource('@(user?.Id)', @(ur.ResourceId))">
                                        Speichern
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Achievements -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Freigeschaltete Achievements (@(userAchievements?.Count ?? 0))</h5>
            </div>
            <div class="card-body">
                @if (userAchievements != null && userAchievements.Any())
                {
                    @foreach (var ua in userAchievements)
                    {
                        <span class="badge bg-success me-1 mb-1">@(ua.Achievement.Name)</span>
                    }
                }
                else
                {
                    <p class="text-muted">Keine Achievements.</p>
                }
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">Dieser Spieler hat noch keine Farm.</div>
    }

    <a asp-action="Players" class="btn btn-secondary mt-3">Zurueck zur Spielerliste</a>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML =
                '<div class="d-flex">' +
                    '<div class="toast-body">' + message + '</div>' +
                    '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '</div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function saveFarm(userId) {
            var data = {
                userId: userId,
                money: parseFloat(document.getElementById('farm-money').value),
                rebirthMultiplier: parseFloat(document.getElementById('farm-multiplier').value),
                rebirthCount: parseInt(document.getElementById('farm-rebirths').value),
                allocationUnlocked: document.getElementById('farm-allocation').value === 'true',
                productionBonus: parseFloat(document.getElementById('farm-prodbonus').value),
                sellBonus: parseFloat(document.getElementById('farm-sellbonus').value),
                upgradeDiscount: parseFloat(document.getElementById('farm-discount').value),
                storageBonus: parseFloat(document.getElementById('farm-storagebonus').value)
            };
            try {
                var response = await fetch('/Admin/AjaxUpdatePlayer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    var result = await response.json();
                    showToast(result.message, 'success');
                } else {
                    showToast(await response.text(), 'danger');
                }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }

        async function saveBuilding(userId, buildingId) {
            var data = {
                userId: userId,
                buildingId: buildingId,
                isUnlocked: document.getElementById('bld-unlocked-' + buildingId).value === 'true',
                productionLevel: parseInt(document.getElementById('bld-prod-' + buildingId).value),
                efficiencyLevel: parseInt(document.getElementById('bld-eff-' + buildingId).value),
                capacityLevel: parseInt(document.getElementById('bld-cap-' + buildingId).value)
            };
            try {
                var response = await fetch('/Admin/AjaxUpdateBuilding', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    var result = await response.json();
                    showToast(result.message, 'success');
                } else {
                    showToast(await response.text(), 'danger');
                }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }

        async function saveResource(userId, resourceId) {
            var data = {
                userId: userId,
                resourceId: resourceId,
                amount: parseFloat(document.getElementById('res-amount-' + resourceId).value),
                maxStorage: parseFloat(document.getElementById('res-max-' + resourceId).value)
            };
            try {
                var response = await fetch('/Admin/AjaxUpdateResource', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    var result = await response.json();
                    showToast(result.message, 'success');
                } else {
                    showToast(await response.text(), 'danger');
                }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }

        async function resetPlayer(userId) {
            if (!confirm('ACHTUNG: Komplett-Reset! Alles wird auf Anfang gesetzt inkl. Multiplikator. Fortfahren?')) return;
            try {
                var response = await fetch('/Admin/AjaxResetPlayer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(userId)
                });
                if (response.ok) {
                    var result = await response.json();
                    showToast(result.message, 'success');
                    setTimeout(function () { location.reload(); }, 1000);
                } else {
                    showToast(await response.text(), 'danger');
                }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }
    </script>
}