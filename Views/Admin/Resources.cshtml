@model List<SEW04_Projekt_Bsteh.Models.Resource>
@{
    ViewData["Title"] = "Ressourcen verwalten";
}

<div class="container mt-4">
    <h1>Ressourcen verwalten</h1>
    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    @foreach (var res in Model)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">@(res.Name)</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <input type="text" id="res-name-@(res.Id)" class="form-control" value="@(res.Name)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Verkaufspreis</label>
                        <input type="number" id="res-price-@(res.Id)" class="form-control" step="0.01" value="@(res.SellPrice.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Kettenposition</label>
                        <input type="number" id="res-chain-@(res.Id)" class="form-control" value="@(res.ChainOrder)" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-primary w-100" onclick="saveResource(@(res.Id))">Speichern</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <a asp-action="Index" class="btn btn-secondary mt-3">Zurück</a>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = '<div class="d-flex"><div class="toast-body">' + message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function saveResource(id) {
            var data = {
                id: id,
                name: document.getElementById('res-name-' + id).value,
                sellPrice: parseFloat(document.getElementById('res-price-' + id).value),
                chainOrder: parseInt(document.getElementById('res-chain-' + id).value)
            };
            try {
                var response = await fetch('/Admin/AjaxEditResource', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) { var r = await response.json(); showToast(r.message, 'success'); }
                else { showToast(await response.text(), 'danger'); }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }
    </script>
}