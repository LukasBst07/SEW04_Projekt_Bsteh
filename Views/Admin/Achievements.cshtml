@model List<SEW04_Projekt_Bsteh.Models.Achievement>
@{
    ViewData["Title"] = "Achievements verwalten";
}

<div class="container mt-4">
    <h1>Achievements verwalten</h1>
    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    @foreach (var a in Model)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">@(a.Name)</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <input type="text" id="ach-name-@(a.Id)" class="form-control" value="@(a.Name)" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Beschreibung</label>
                        <input type="text" id="ach-desc-@(a.Id)" class="form-control" value="@(a.Description)" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Bonus-Typ</label>
                        <input type="text" id="ach-type-@(a.Id)" class="form-control" value="@(a.BonusType)" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Bonus-Wert</label>
                        <input type="number" id="ach-value-@(a.Id)" class="form-control" step="0.01" value="@(a.BonusValue.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-8">
                        <label class="form-label">Bonus-Beschreibung</label>
                        <input type="text" id="ach-bonusdesc-@(a.Id)" class="form-control" value="@(a.BonusDescription)" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-primary w-100" onclick="saveAchievement(@(a.Id))">Speichern</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <a asp-action="Index" class="btn btn-secondary mt-3">Zurueck</a>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = '<div class="d-flex"><div class="toast-body">' + message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function saveAchievement(id) {
            var data = {
                id: id,
                name: document.getElementById('ach-name-' + id).value,
                description: document.getElementById('ach-desc-' + id).value,
                bonusType: document.getElementById('ach-type-' + id).value,
                bonusValue: parseFloat(document.getElementById('ach-value-' + id).value),
                bonusDescription: document.getElementById('ach-bonusdesc-' + id).value
            };
            try {
                var response = await fetch('/Admin/AjaxEditAchievement', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) { var r = await response.json(); showToast(r.message, 'success'); }
                else { showToast(await response.text(), 'danger'); }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }
    </script>
}