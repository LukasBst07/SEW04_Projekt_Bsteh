@model List<SEW04_Projekt_Bsteh.Models.Building>
@{
    ViewData["Title"] = "Gebaeude verwalten";
}

<div class="container mt-4">
    <h1>Gebaeude verwalten</h1>
    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    @foreach (var b in Model)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">@(b.Name)</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <input type="text" id="bld-name-@(b.Id)" class="form-control" value="@(b.Name)" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Beschreibung</label>
                        <input type="text" id="bld-desc-@(b.Id)" class="form-control" value="@(b.Description)" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Kaufpreis</label>
                        <input type="number" id="bld-cost-@(b.Id)" class="form-control" step="1" value="@(b.BaseCost.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Produktion/s</label>
                        <input type="number" id="bld-rate-@(b.Id)" class="form-control" step="0.01" value="@(b.BaseProductionRate.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <label class="form-label">Input pro Output</label>
                        <input type="number" id="bld-ipo-@(b.Id)" class="form-control" step="0.1" value="@(b.InputPerOutput.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Input</label>
                        <input type="text" class="form-control" value="@(b.InputResource?.Name ?? "Keiner")" disabled />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Output</label>
                        <input type="text" class="form-control" value="@(b.OutputResource.Name)" disabled />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-primary w-100" onclick="saveBuilding(@(b.Id))">Speichern</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <a asp-action="Index" class="btn btn-secondary mt-3">Zurueck</a>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = '<div class="d-flex"><div class="toast-body">' + message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function saveBuilding(id) {
            var data = {
                id: id,
                name: document.getElementById('bld-name-' + id).value,
                description: document.getElementById('bld-desc-' + id).value,
                baseCost: parseFloat(document.getElementById('bld-cost-' + id).value),
                baseProductionRate: parseFloat(document.getElementById('bld-rate-' + id).value),
                inputPerOutput: parseFloat(document.getElementById('bld-ipo-' + id).value)
            };
            try {
                var response = await fetch('/Admin/AjaxEditBuilding', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) { var r = await response.json(); showToast(r.message, 'success'); }
                else { showToast(await response.text(), 'danger'); }
            } catch (e) { showToast('Fehler!', 'danger'); }
        }
    </script>
}