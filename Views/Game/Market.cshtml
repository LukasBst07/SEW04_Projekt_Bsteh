@{
    ViewData["Title"] = "Marktplatz";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userResources = ViewBag.UserResources as List<SEW04_Projekt_Bsteh.Models.UserResource>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Marktplatz</h1>
        <span class="badge bg-dark fs-6">Geld: @(farm?.Money.ToString("F2"))</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        @if (userResources != null)
        {
            @foreach (var ur in userResources)
            {
                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5 class="mb-0">@(ur.Resource.Name)</h5>
                        </div>
                        <div class="card-body">
                            <p>Verfuegbar: <strong>@(ur.Amount.ToString("F1"))</strong></p>
                            <p>Preis pro Stueck: <strong>@(ur.Resource.SellPrice)</strong></p>
                            <p>Gesamtwert: <strong>@((ur.Amount * (double)ur.Resource.SellPrice).ToString("F2"))</strong></p>

                            <hr />
                            <form asp-action="SellResource" method="post">
                                <input type="hidden" name="resourceId" value="@(ur.ResourceId)" />
                                <div class="input-group mb-2">
                                    <input type="number" name="amount" class="form-control" step="0.1" min="0" max="@(ur.Amount)" placeholder="Menge" />
                                    <button class="btn btn-warning" type="submit">Verkaufen</button>
                                </div>
                            </form>

                            <form asp-action="SellResource" method="post">
                                <input type="hidden" name="resourceId" value="@(ur.ResourceId)" />
                                <input type="hidden" name="amount" value="@(ur.Amount)" />
                                <button class="btn btn-outline-warning btn-sm w-100">Alles verkaufen</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <a asp-action="Dashboard" class="btn btn-secondary mt-3">Zurueck zum Dashboard</a>
</div>