@{
    ViewData["Title"] = "Marktplatz";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userResources = ViewBag.UserResources as List<SEW04_Projekt_Bsteh.Models.UserResource>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Marktplatz</h1>
        <span class="badge bg-dark fs-6" id="moneyDisplay">Geld: @(farm?.Money.ToString("F2"))</span>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    <div class="alert alert-info">
        <strong>Hinweis:</strong> Am Marktplatz kannst du Ressourcen sofort verkaufen. Der Marktpreis beträgt 80% des regulären Preises.
    </div>

    <div class="row">
        @if (userResources != null)
        {
            @foreach (var ur in userResources)
            {
                var marketPrice = ur.Resource.SellPrice * 0.8m;

                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5 class="mb-0">@(ur.Resource.Name)</h5>
                        </div>
                        <div class="card-body">
                            <p>Verfügbar: <strong id="available-@(ur.ResourceId)">@(ur.Amount.ToString("F1"))</strong></p>
                            <p>Marktpreis: <strong>@(marketPrice.ToString(System.Globalization.CultureInfo.InvariantCulture))</strong> / Stück</p>

                            <hr />
                            <button class="btn btn-warning w-100"
                                    onclick="verkaufen(@(ur.ResourceId))">
                                Alles verkaufen
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <a asp-action="Dashboard" class="btn btn-secondary mt-3">Zurück zum Dashboard</a>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML =
                '<div class="d-flex">' +
                    '<div class="toast-body">' + message + '</div>' +
                    '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '</div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function verkaufen(resourceId) {
            var amount = parseFloat(document.getElementById('available-' + resourceId).innerText);
            if (!amount || amount <= 0) {
                showToast('Nichts zu verkaufen!', 'danger');
                return;
            }

            try {
                var response = await fetch('/Game/AjaxQuickSell', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ resourceId: resourceId, amount: amount })
                });
                if (response.ok) {
                    var data = await response.json();
                    showToast(data.message, 'success');
                } else {
                    var error = await response.text();
                    showToast(error, 'danger');
                }
            } catch (e) {
                showToast('Fehler beim Verkaufen.', 'danger');
            }
        }

        async function updateMarket() {
            try {
                var response = await fetch('/Game/GetGameState');
                if (!response.ok) return;
                var data = await response.json();

                document.getElementById('moneyDisplay').innerText = 'Geld: ' + data.money.toFixed(2);

                data.resources.forEach(function (res) {
                    var available = document.getElementById('available-' + res.id);
                    if (available) available.innerText = res.amount.toFixed(1);
                });
            } catch (e) { }
        }

        setInterval(updateMarket, 500);
    </script>
}