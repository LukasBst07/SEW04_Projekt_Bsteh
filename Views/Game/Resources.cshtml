@{
    ViewData["Title"] = "Ressourcen";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userResources = ViewBag.UserResources as List<SEW04_Projekt_Bsteh.Models.UserResource>;
    var allocations = ViewBag.Allocations as List<SEW04_Projekt_Bsteh.Models.ResourceAllocation>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Ressourcen</h1>
        <span class="badge bg-dark fs-6">Geld: @(farm?.Money.ToString("F2"))</span>
    </div>

    <div class="row">
        @if (userResources != null && allocations != null)
        {
            @foreach (var ur in userResources)
            {
                var alloc = allocations.FirstOrDefault(a => a.ResourceId == ur.ResourceId);
                var sellPct = alloc?.SellPercentage ?? 100;

                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5 class="mb-0">@(ur.Resource.Name)</h5>
                        </div>
                        <div class="card-body">
                            <p>Menge: <strong>@(ur.Amount.ToString("F1"))</strong> / @(ur.MaxStorage)</p>
                            <div class="progress mb-3">
                                <div class="progress-bar" style="width: @((ur.Amount / ur.MaxStorage * 100).ToString("F0"))%">
                                    @((ur.Amount / ur.MaxStorage * 100).ToString("F0"))%
                                </div>
                            </div>

                            <p>Verkaufspreis: @(ur.Resource.SellPrice) pro Stueck</p>

                            <hr />
                            <h6>Verteilung</h6>
                            <form asp-action="UpdateAllocation" method="post">
                                <input type="hidden" name="resourceId" value="@(ur.ResourceId)" />
                                <div class="mb-2">
                                    <label>Verkauf: <strong id="sell-@(ur.ResourceId)">@(sellPct)%</strong></label>
                                    <br />
                                    <label>Weiterverarbeitung: <strong id="process-@(ur.ResourceId)">@(100 - sellPct)%</strong></label>
                                </div>
                                <input type="range" class="form-range" name="sellPercentage"
                                       min="0" max="100" step="5" value="@(sellPct)"
                                       oninput="document.getElementById('sell-@(ur.ResourceId)').innerText=this.value+'%'; document.getElementById('process-@(ur.ResourceId)').innerText=(100-this.value)+'%';" />
                                <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">Speichern</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <a asp-action="Dashboard" class="btn btn-secondary mt-3">Zurueck zum Dashboard</a>
</div>