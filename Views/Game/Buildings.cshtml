@{
    ViewData["Title"] = "Gebaeude";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userBuildings = ViewBag.UserBuildings as List<SEW04_Projekt_Bsteh.Models.UserBuilding>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Gebaeude</h1>
        <div>
            <span class="badge bg-dark fs-6">Geld: @(farm?.Money.ToString("F2"))</span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        @if (userBuildings != null)
        {
            @foreach (var ub in userBuildings)
            {
                <div class="col-md-4">
                    <div class="card mb-3 @(ub.IsUnlocked ? "" : "opacity-50")">
                        <div class="card-header">
                            <h5 class="mb-0">@(ub.Building.Name)</h5>
                        </div>
                        <div class="card-body">
                            <p>@(ub.Building.Description)</p>

                            @if (ub.Building.InputResource != null)
                            {
                                <p>Input: @(ub.Building.InputResource.Name) (@(ub.Building.InputPerOutput):1)</p>
                            }
                            <p>Output: @(ub.Building.OutputResource.Name)</p>
                            <p>Basisproduktion: @(ub.Building.BaseProductionRate)/s</p>

                            @if (ub.IsUnlocked)
                            {
                                <hr />
                                <form asp-action="UpgradeBuilding" method="post" class="mb-1">
                                    <input type="hidden" name="buildingId" value="@(ub.BuildingId)" />
                                    <input type="hidden" name="upgradeType" value="production" />
                                    <button class="btn btn-outline-primary btn-sm w-100">
                                        Produktion Lv. @(ub.ProductionLevel) → @(ub.ProductionLevel + 1)
                                        (Kosten: @(Math.Max(50, (double)ub.Building.BaseCost * (ub.ProductionLevel + 1) * 0.5).ToString("F0")))
                                    </button>
                                </form>

                                <form asp-action="UpgradeBuilding" method="post" class="mb-1">
                                    <input type="hidden" name="buildingId" value="@(ub.BuildingId)" />
                                    <input type="hidden" name="upgradeType" value="efficiency" />
                                    <button class="btn btn-outline-info btn-sm w-100">
                                        Effizienz Lv. @(ub.EfficiencyLevel) → @(ub.EfficiencyLevel + 1)
                                        (Kosten: @(Math.Max(50, (double)ub.Building.BaseCost * (ub.EfficiencyLevel + 1) * 0.5).ToString("F0")))
                                    </button>
                                </form>

                                <form asp-action="UpgradeBuilding" method="post" class="mb-1">
                                    <input type="hidden" name="buildingId" value="@(ub.BuildingId)" />
                                    <input type="hidden" name="upgradeType" value="capacity" />
                                    <button class="btn btn-outline-warning btn-sm w-100">
                                        Kapazitaet Lv. @(ub.CapacityLevel) → @(ub.CapacityLevel + 1)
                                        (Kosten: @(Math.Max(50, (double)ub.Building.BaseCost * (ub.CapacityLevel + 1) * 0.5).ToString("F0")))
                                    </button>
                                </form>
                            }
                            else
                            {
                                <hr />
                                <form asp-action="BuyBuilding" method="post">
                                    <input type="hidden" name="buildingId" value="@(ub.BuildingId)" />
                                    <button class="btn btn-primary w-100">
                                        Kaufen - @(ub.Building.BaseCost) Muenzen
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <a asp-action="Dashboard" class="btn btn-secondary mt-3">Zurueck zum Dashboard</a>
</div>