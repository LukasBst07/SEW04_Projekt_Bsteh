@{
    ViewData["Title"] = "Gebaeude";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userBuildings = ViewBag.UserBuildings as List<SEW04_Projekt_Bsteh.Models.UserBuilding>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Gebaeude</h1>
        <span class="badge bg-dark fs-6" id="moneyDisplay">Geld: @(farm?.Money.ToString("F2"))</span>
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    <div class="row">
        @if (userBuildings != null)
        {
            @foreach (var ub in userBuildings)
            {
                <div class="col-md-4" id="building-card-@(ub.BuildingId)">
                    <div class="card mb-3 @(ub.IsUnlocked ? "" : "opacity-50")">
                        <div class="card-header">
                            <h5 class="mb-0">@(ub.Building.Name)</h5>
                        </div>
                        <div class="card-body">
                            <p>@(ub.Building.Description)</p>

                            @if (ub.Building.InputResource != null)
                            {
                                <p>Input: @(ub.Building.InputResource.Name) (@(ub.Building.InputPerOutput):1)</p>
                            }
                            <p>Output: @(ub.Building.OutputResource.Name)</p>
                            <p>Basisproduktion: @(ub.Building.BaseProductionRate)/s</p>

                            <div id="building-status-@(ub.BuildingId)">
                                @if (ub.IsUnlocked)
                                {
                                    <hr />
                                    <button class="btn btn-outline-primary btn-sm w-100 mb-1"
                                            onclick="upgradeBuilding(@(ub.BuildingId), 'production')">
                                        Produktion Lv. <span id="prod-lvl-@(ub.BuildingId)">@(ub.ProductionLevel)</span>
                                        → <span id="prod-next-@(ub.BuildingId)">@(ub.ProductionLevel + 1)</span>
                                    </button>

                                    <button class="btn btn-outline-info btn-sm w-100 mb-1"
                                            onclick="upgradeBuilding(@(ub.BuildingId), 'efficiency')">
                                        Effizienz Lv. <span id="eff-lvl-@(ub.BuildingId)">@(ub.EfficiencyLevel)</span>
                                        → <span id="eff-next-@(ub.BuildingId)">@(ub.EfficiencyLevel + 1)</span>
                                    </button>

                                    <button class="btn btn-outline-warning btn-sm w-100 mb-1"
                                            onclick="upgradeBuilding(@(ub.BuildingId), 'capacity')">
                                        Kapazitaet Lv. <span id="cap-lvl-@(ub.BuildingId)">@(ub.CapacityLevel)</span>
                                        → <span id="cap-next-@(ub.BuildingId)">@(ub.CapacityLevel + 1)</span>
                                    </button>
                                }
                                else
                                {
                                    <hr />
                                    <button class="btn btn-primary w-100" onclick="buyBuilding(@(ub.BuildingId))">
                                        Kaufen - @(ub.Building.BaseCost) Muenzen
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <a asp-action="Dashboard" class="btn btn-secondary mt-3">Zurueck zum Dashboard</a>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML =
                '<div class="d-flex">' +
                    '<div class="toast-body">' + message + '</div>' +
                    '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '</div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function buyBuilding(buildingId) {
            try {
                var response = await fetch('/Game/AjaxBuyBuilding', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(buildingId)
                });
                if (response.ok) {
                    var data = await response.json();
                    showToast(data.message, 'success');
                    setTimeout(function () { location.reload(); }, 500);
                } else {
                    var error = await response.text();
                    showToast(error, 'danger');
                }
            } catch (e) {
                showToast('Fehler beim Kaufen.', 'danger');
            }
        }

        async function upgradeBuilding(buildingId, upgradeType) {
            try {
                var response = await fetch('/Game/AjaxUpgradeBuilding', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ buildingId: buildingId, upgradeType: upgradeType })
                });
                if (response.ok) {
                    var data = await response.json();
                    showToast(data.message, 'success');
                    await refreshState();

                    if (upgradeType === 'production') {
                        var lvl = document.getElementById('prod-lvl-' + buildingId);
                        var next = document.getElementById('prod-next-' + buildingId);
                        if (lvl && next) { var c = parseInt(lvl.innerText) + 1; lvl.innerText = c; next.innerText = c + 1; }
                    } else if (upgradeType === 'efficiency') {
                        var lvl = document.getElementById('eff-lvl-' + buildingId);
                        var next = document.getElementById('eff-next-' + buildingId);
                        if (lvl && next) { var c = parseInt(lvl.innerText) + 1; lvl.innerText = c; next.innerText = c + 1; }
                    } else if (upgradeType === 'capacity') {
                        var lvl = document.getElementById('cap-lvl-' + buildingId);
                        var next = document.getElementById('cap-next-' + buildingId);
                        if (lvl && next) { var c = parseInt(lvl.innerText) + 1; lvl.innerText = c; next.innerText = c + 1; }
                    }
                } else {
                    var error = await response.text();
                    showToast(error, 'danger');
                }
            } catch (e) {
                showToast('Fehler beim Upgrade.', 'danger');
            }
        }

        async function refreshState() {
            try {
                var response = await fetch('/Game/GetGameState');
                if (!response.ok) return;
                var data = await response.json();
                document.getElementById('moneyDisplay').innerText = 'Geld: ' + data.money.toFixed(2);
            } catch (e) { }
        }

        setInterval(refreshState, 500);
    </script>
}