@{
    ViewData["Title"] = "Dashboard";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userBuildings = ViewBag.UserBuildings as List<SEW04_Projekt_Bsteh.Models.UserBuilding>;
    var userResources = ViewBag.UserResources as List<SEW04_Projekt_Bsteh.Models.UserResource>;
}

<div class="container mt-4">
    <h1>HarvestDynasty - Dashboard</h1>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    <!-- Finanzen -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6>Geld</h6>
                    <h4 id="money">@(farm?.Money.ToString("F2"))</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6>Multiplikator</h6>
                    <h4 id="multiplier">x@(farm?.RebirthMultiplier.ToString("F1"))</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6>Rebirths</h6>
                    <h4 id="rebirths">@(farm?.RebirthCount)</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Ressourcen -->
    <h4>Ressourcen</h4>
    <div class="row mb-4" id="resourcesContainer">
        @if (userResources != null)
        {
            @foreach (var ur in userResources)
            {
                <div class="col-md-4">
                    <div class="card mb-2">
                        <div class="card-body">
                            <h6>@(ur.Resource.Name)</h6>
                            <div class="progress">
                                <div class="progress-bar" id="bar-@(ur.ResourceId)"
                                     style="width: @((ur.Amount / ur.MaxStorage * 100).ToString("F0"))%">
                                    <span id="res-@(ur.ResourceId)">@(ur.Amount.ToString("F1")) / @(ur.MaxStorage)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Gebaeude -->
    <h4>Gebaeude</h4>
    <div class="row mb-4" id="buildingsContainer">
        @if (userBuildings != null)
        {
            @foreach (var ub in userBuildings)
            {
                <div class="col-md-4">
                    <div class="card mb-2" id="building-@(ub.BuildingId)">
                        <div class="card-body">
                            <h6>@(ub.Building.Name)</h6>
                            @if (ub.IsUnlocked)
                            {
                                <span class="badge bg-success">Aktiv</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Gesperrt</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Navigation -->
    <h4>Aktionen</h4>
    <div class="row">
        <div class="col-md-2">
            <a asp-action="Buildings" class="btn btn-primary w-100 mb-2">Gebaeude</a>
        </div>
        <div class="col-md-2">
            <a asp-action="Resources" class="btn btn-success w-100 mb-2">Ressourcen</a>
        </div>
        <div class="col-md-2">
            <a asp-action="Market" class="btn btn-warning w-100 mb-2">Marktplatz</a>
        </div>
        <div class="col-md-2">
            <a asp-action="Achievements" class="btn btn-info w-100 mb-2">Achievements</a>
        </div>
        <div class="col-md-2">
            <a asp-action="Profile" class="btn btn-secondary w-100 mb-2">Profil</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Bekannte Achievement-IDs um neue zu erkennen
        let knownAchievements = [];
        let firstLoad = true;

        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML =
                '<div class="d-flex">' +
                    '<div class="toast-body">' + message + '</div>' +
                    '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '</div>';
            container.appendChild(toast);

            setTimeout(function () {
                toast.remove();
            }, 4000);
        }

        async function updateGameState() {
            try {
                var response = await fetch('/Game/GetGameState');
                if (!response.ok) return;

                var data = await response.json();

                // Geld aktualisieren
                document.getElementById('money').innerText = data.money.toFixed(2);
                document.getElementById('multiplier').innerText = 'x' + data.rebirthMultiplier.toFixed(1);
                document.getElementById('rebirths').innerText = data.rebirthCount;

                // Ressourcen aktualisieren
                data.resources.forEach(function (res) {
                    var bar = document.getElementById('bar-' + res.id);
                    var text = document.getElementById('res-' + res.id);
                    if (bar && text) {
                        var percent = (res.amount / res.maxStorage * 100).toFixed(0);
                        bar.style.width = percent + '%';
                        text.innerText = res.amount.toFixed(1) + ' / ' + res.maxStorage;
                    }
                });

                // Gebaeude Status aktualisieren
                data.buildings.forEach(function (b) {
                    var card = document.getElementById('building-' + b.id);
                    if (card) {
                        var badge = card.querySelector('.badge');
                        if (badge) {
                            if (b.isUnlocked) {
                                badge.className = 'badge bg-success';
                                badge.innerText = 'Aktiv';
                            } else {
                                badge.className = 'badge bg-secondary';
                                badge.innerText = 'Gesperrt';
                            }
                        }
                    }
                });

                // Neue Achievements erkennen und Toast anzeigen
                if (firstLoad) {
                    knownAchievements = data.achievements;
                    firstLoad = false;
                } else {
                    data.achievements.forEach(function (id) {
                        if (!knownAchievements.includes(id)) {
                            showToast('Achievement freigeschaltet!', 'success');
                            knownAchievements.push(id);
                        }
                    });
                }

            } catch (e) {
                console.error('Update failed:', e);
            }
        }

        // 2x pro Sekunde aktualisieren
        setInterval(updateGameState, 500);

        // Sofort beim Laden einmal ausfuehren
        updateGameState();
    </script>
}