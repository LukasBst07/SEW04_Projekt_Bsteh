@{
    ViewData["Title"] = "Profil";

    var farm = ViewBag.Farm as SEW04_Projekt_Bsteh.Models.Farm;
    var userBuildings = ViewBag.UserBuildings as List<SEW04_Projekt_Bsteh.Models.UserBuilding>;
    var achievementCount = ViewBag.AchievementCount as int? ?? 0;
    var totalAchievements = ViewBag.TotalAchievements as int? ?? 0;
    var userEmail = ViewBag.UserEmail as string;
    var allAchievementsUnlocked = achievementCount >= totalAchievements;
}

<div class="container mt-4">
    <h1>Profil</h1>

    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Spieler</h5>
                </div>
                <div class="card-body">
                    <p>E-Mail: <strong>@(userEmail)</strong></p>
                    <p>Geld: <strong id="profileMoney">@(farm?.Money.ToString("F2"))</strong></p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Statistiken</h5>
                </div>
                <div class="card-body">
                    <p>Gebäude freigeschaltet: <strong>@(userBuildings?.Count(ub => ub.IsUnlocked) ?? 0) / @(userBuildings?.Count ?? 0)</strong></p>
                    <p>Achievements: <strong>@(achievementCount) / @(totalAchievements)</strong></p>
                    <p>Rebirths: <strong id="profileRebirths">@(farm?.RebirthCount)</strong></p>
                    <p>Multiplikator: <strong id="profileMulti">x@(farm?.RebirthMultiplier.ToString("F1"))</strong></p>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">Aktive Achievement-Boni</h5>
        </div>
        <div class="card-body">
            <p>Verteilung: <strong>@(farm != null && farm.AllocationUnlocked ? "Freigeschaltet" : "Gesperrt")</strong></p>
            <p>Produktionsbonus: <strong>+@((farm?.AchievementProductionBonus * 100 ?? 0).ToString("F0"))%</strong></p>
            <p>Verkaufsbonus: <strong>+@((farm?.AchievementSellBonus * 100 ?? 0).ToString("F0"))%</strong></p>
            <p>Upgrade-Rabatt: <strong>-@((farm?.AchievementUpgradeDiscount * 100 ?? 0).ToString("F0"))%</strong></p>
            <p>Lagerbonus: <strong>+@((farm?.AchievementStorageBonus * 100 ?? 0).ToString("F0"))%</strong></p>
        </div>
    </div>

    <div class="card mb-3 @(allAchievementsUnlocked ? "border-warning" : "")">
        <div class="card-header">
            <h5 class="mb-0">Rebirth</h5>
        </div>
        <div class="card-body">
            <p>Setze deine Farm zurück und erhalte einen dauerhaften Multiplikator.</p>
            <p>Aktueller Multiplikator: <strong>x@(farm?.RebirthMultiplier.ToString("F1"))</strong></p>
            <p>Nach Rebirth: <strong>x@((farm != null ? farm.RebirthMultiplier + 0.8 : 1.8).ToString("F1"))</strong></p>

            <div class="alert alert-warning mt-3">
                <strong>Achtung:</strong> Rebirth setzt zurück: Geld, Gebäude, Upgrades, Ressourcen, Achievements und alle Boni.
                Nur der Multiplikator und die Rebirth-Anzahl bleiben.
            </div>

            @if (allAchievementsUnlocked)
            {
                <button class="btn btn-warning w-100" data-bs-toggle="modal" data-bs-target="#rebirthModal">
                    Rebirth durchführen
                </button>
            }
            else
            {
                <button class="btn btn-secondary w-100" disabled>
                    Alle Achievements freischalten um Rebirth zu nutzen (@(achievementCount)/@(totalAchievements))
                </button>
            }
        </div>
    </div>

    <a asp-action="Dashboard" class="btn btn-secondary mt-3">Zurück zum Dashboard</a>
</div>

<!-- Rebirth Modal -->
<div class="modal fade" id="rebirthModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(90deg, #52b788, #40916c); color: white;">
                <h5 class="modal-title">Rebirth bestätigen</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bist du sicher? <strong>Alles wird zurückgesetzt:</strong></p>
                <ul>
                    <li>Geld → 100</li>
                    <li>Alle Gebäude gesperrt (außer Feld)</li>
                    <li>Alle Upgrades auf Level 0</li>
                    <li>Alle Ressourcen auf 0</li>
                    <li>Alle Achievements verloren</li>
                    <li>Alle Boni weg</li>
                </ul>
                <p><strong>Dafür bekommst du:</strong></p>
                <ul>
                    <li>Multiplikator +0.8 (permanent)</li>
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-warning" onclick="doRebirth()">Ja, Rebirth!</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showToast(message, type) {
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast show align-items-center text-white bg-' + type + ' border-0';
            toast.setAttribute('role', 'alert');
            toast.innerHTML =
                '<div class="d-flex">' +
                    '<div class="toast-body">' + message + '</div>' +
                    '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
                '</div>';
            container.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 4000);
        }

        async function doRebirth() {
            try {
                var modal = bootstrap.Modal.getInstance(document.getElementById('rebirthModal'));
                modal.hide();

                var response = await fetch('/Game/AjaxRebirth', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    var data = await response.json();
                    showToast(data.message, 'success');
                    setTimeout(function () { window.location.href = '/Game/Dashboard'; }, 1500);
                } else {
                    var error = await response.text();
                    showToast(error, 'danger');
                }
            } catch (e) {
                showToast('Fehler beim Rebirth.', 'danger');
            }
        }

        async function updateProfile() {
            try {
                var response = await fetch('/Game/GetGameState');
                if (!response.ok) return;
                var data = await response.json();

                document.getElementById('profileMoney').innerText = data.money.toFixed(2);
                document.getElementById('profileRebirths').innerText = data.rebirthCount;
                document.getElementById('profileMulti').innerText = 'x' + data.rebirthMultiplier.toFixed(1);
            } catch (e) { }
        }

        setInterval(updateProfile, 500);
    </script>
}
